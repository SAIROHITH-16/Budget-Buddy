# .env.example — Frontend (Vite) environment variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# How to get these values:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → Project settings → General
#   3. Scroll to "Your apps" → select your Web app (or add one)
#   4. Copy the firebaseConfig object values into the variables below

# -----------------------------------------------------------------
# Firebase Client SDK — used by the React frontend
# -----------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSy_replace_me
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# -----------------------------------------------------------------
# Express backend URL — where the React frontend sends API requests
# In development this should match the PORT in server/.env
# -----------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------
# Supabase — used by the React frontend to call Edge Functions
# Get these from: https://supabase.com/dashboard/project/_/settings/api
#   Project URL  → VITE_SUPABASE_URL
#   anon/public key → VITE_SUPABASE_PUBLISHABLE_KEY
# -----------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
