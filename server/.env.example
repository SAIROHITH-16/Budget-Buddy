# server/.env.example — Express backend environment variables
# Copy this file to server/.env and fill in your actual values.
# NEVER commit server/.env to version control.
#
# How to get Firebase service account credentials:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → Project settings → Service accounts
#   3. Click "Generate new private key" → download the JSON file
#   4. Copy values from the JSON into the variables below

# -----------------------------------------------------------------
# Express server
# -----------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------
# MongoDB connection string
# Atlas (recommended — free tier): https://cloud.mongodb.com
#   → Create cluster → Connect → Drivers → copy the string below
# Local: mongodb://localhost:27017/budget-buddy
# -----------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/budget-buddy?retryWrites=true&w=majority

# -----------------------------------------------------------------
# CORS — the frontend origin allowed to call this API
# Development: http://localhost:8080 (matches vite.config.ts port)
#   Note: Vite may use 8081/8082 if 8080 is taken — check terminal output
# Production:  https://your-deployed-frontend.com
# -----------------------------------------------------------------
CORS_ORIGIN=http://localhost:8080

# -----------------------------------------------------------------
# Firebase Admin SDK — from the service account JSON file
# project_id          → project_id
# private_key_id      → private_key_id
# private_key         → private_key  (the full PEM string, keep the \n escapes)
# client_email        → client_email
# client_id           → client_id
# -----------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=replace_with_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=replace_with_client_id
# -----------------------------------------------------------------
# GitHub Models (GPT-4o AI categorisation & insights)
# Required for auto-categorising transactions and the Insights page.
# Without this the app still works — categories fall back to "Uncategorized".
#
# How to create the token:
#   1. Go to https://github.com/settings/tokens  (classic or fine-grained)
#   2. Generate a new token and tick the "Models" permission
#      (shown as "models:read" or "GitHub Models access" depending on token type)
#   3. Copy the token and paste it below.
# -----------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here

# -----------------------------------------------------------------
# Nodemailer — Gmail OTP emails
# Used to send the 6-digit email verification code to new users.
#
# MAIL_USER  — your Gmail address (e.g. yourapp@gmail.com)
# MAIL_PASS  — a Gmail App Password (NOT your real Gmail password)
#
# How to create a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select app "Mail" and device "Other" → click Generate
#   4. Paste the 16-character password (no spaces) into MAIL_PASS below
# -----------------------------------------------------------------
MAIL_USER=yourapp@gmail.com
MAIL_PASS=your_16_char_app_password

# -----------------------------------------------------------------
# Phone.Email — phone number OTP sign-in
# Used by POST /api/auth/verify-phone-email to verify the widget callback.
#
# How to get these values:
#   1. Create a free account at https://phone.email
#   2. Dashboard → Add App → copy the Client ID
#   3. Dashboard → App settings → copy the Client Secret
#
# VITE_PHONE_EMAIL_CLIENT_ID goes in the FRONTEND .env (Vercel env vars)
# PHONE_EMAIL_CLIENT_SECRET goes here on the BACKEND (Render env vars)
# -----------------------------------------------------------------
PHONE_EMAIL_CLIENT_SECRET=your_phone_email_client_secret_here