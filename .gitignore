# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Backend environment variables — never commit real credentials
server/.env
.env

# SQLite database files — created automatically by the server on first run.
# Never commit these: they are binary, contain user data, and Render/cloud
# hosting has an ephemeral filesystem that resets on every deploy anyway.
server/data/*.db
server/data/*.db-shm
server/data/*.db-wal
server/data/*.db-journal

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
