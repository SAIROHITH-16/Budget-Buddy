{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://budget-buddy-1-wkm2.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
